// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ПОЛЬЗОВАТЕЛИ И ДОСТУП
// ─────────────────────────────────────────────

enum UserStatus {
  pending  // ожидает одобрения платформой
  active   // одобрен
  blocked
}

enum PlatformRole {
  user
  platform_admin
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  name         String?
  avatarUrl    String?      @map("avatar_url")
  status       UserStatus   @default(pending)
  platformRole PlatformRole @default(user) @map("platform_role")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  memberships  CompanyMember[]
  assignedCards Card[]        @relation("CardAssignee")
  cardEvents   CardEvent[]

  @@map("users")
}

// ─────────────────────────────────────────────
// КОМПАНИИ
// ─────────────────────────────────────────────

enum CompanyMemberRole {
  admin
  member
}

model Company {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique @map("invite_code")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  members          CompanyMember[]
  avitoIntegration AvitoIntegration?
  telegramConfig   TelegramConfig?
  agents           Agent[]
  listings         Listing[]
  contacts         Contact[]
  cards            Card[]

  @@map("companies")
}

model CompanyMember {
  id        String            @id @default(cuid())
  userId    String            @map("user_id")
  companyId String            @map("company_id")
  role      CompanyMemberRole @default(member)
  createdAt DateTime          @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("company_members")
}

// ─────────────────────────────────────────────
// ИНТЕГРАЦИИ
// ─────────────────────────────────────────────

model AvitoIntegration {
  id           String    @id @default(cuid())
  companyId    String    @unique @map("company_id")
  clientId     String    @map("client_id")
  clientSecret String    @map("client_secret")
  accessToken  String?   @map("access_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("avito_integrations")
}

model TelegramConfig {
  id        String  @id @default(cuid())
  companyId String  @unique @map("company_id")
  botToken  String  @map("bot_token")
  chatId    String? @map("chat_id")

  // Типы уведомлений
  notifyHumanRequired Boolean @default(true) @map("notify_human_required")
  notifyNewDeal       Boolean @default(true) @map("notify_new_deal")
  notifyDealToExecute Boolean @default(true) @map("notify_deal_to_execute")
  notifyDealClosed    Boolean @default(true) @map("notify_deal_closed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("telegram_configs")
}

// ─────────────────────────────────────────────
// AI-АГЕНТ
// ─────────────────────────────────────────────

model Agent {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  name         String   @default("Основной агент")
  systemPrompt String?  @map("system_prompt") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@map("agents")
}

// ─────────────────────────────────────────────
// ОБЪЯВЛЕНИЯ
// ─────────────────────────────────────────────

model Listing {
  id               String   @id @default(cuid())
  companyId        String   @map("company_id")
  avitoId          String   @map("avito_id")
  title            String
  description      String?  @db.Text
  price            Decimal? @db.Decimal(12, 2)
  photoUrls        String[] @map("photo_urls")
  deliveryEnabled  Boolean  @default(false) @map("delivery_enabled")
  aiEnabled        Boolean  @default(true) @map("ai_enabled")
  isActive         Boolean  @default(true) @map("is_active")
  syncedAt         DateTime? @map("synced_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@unique([companyId, avitoId])
  @@map("listings")
}

// ─────────────────────────────────────────────
// КОНТАКТЫ (ПОКУПАТЕЛИ)
// ─────────────────────────────────────────────

model Contact {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  avitoUserId String   @map("avito_user_id")
  name        String?
  avatarUrl   String?  @map("avatar_url")
  phone       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@unique([companyId, avitoUserId])
  @@map("contacts")
}

// ─────────────────────────────────────────────
// ВОРОНКА: РАСШИРЯЕМЫЕ СТАТУСЫ
// ─────────────────────────────────────────────

// Источник перехода статуса
enum TransitionSource {
  ai
  user
  avito
  n8n
  system
}

model CardStatus {
  id        String  @id @default(cuid())
  slug      String  @unique
  label     String
  isClosed  Boolean @default(false) @map("is_closed")
  sortOrder Int     @default(0) @map("sort_order")
  color     String? // hex цвет для UI

  fromTransitions StatusTransition[] @relation("FromStatus")
  toTransitions   StatusTransition[] @relation("ToStatus")
  cards           Card[]
  fromEvents      CardEvent[]        @relation("EventFromStatus")
  toEvents        CardEvent[]        @relation("EventToStatus")

  @@map("card_statuses")
}

// Разрешённые переходы между статусами
model StatusTransition {
  id             String           @id @default(cuid())
  fromStatusId   String           @map("from_status_id")
  toStatusId     String           @map("to_status_id")
  allowedSources TransitionSource[] @map("allowed_sources")

  fromStatus CardStatus @relation("FromStatus", fields: [fromStatusId], references: [id])
  toStatus   CardStatus @relation("ToStatus", fields: [toStatusId], references: [id])

  @@unique([fromStatusId, toStatusId])
  @@map("status_transitions")
}

// ─────────────────────────────────────────────
// КАРТОЧКИ — ГЛАВНЫЙ ОБЪЕКТ
// ─────────────────────────────────────────────

model Card {
  id                  String    @id @default(cuid())
  companyId           String    @map("company_id")
  contactId           String    @map("contact_id")
  listingId           String    @map("listing_id")
  agentId             String?   @map("agent_id")
  assigneeId          String?   @map("assignee_id")
  statusId            String    @map("status_id")

  // AI-состояние (хранится отдельно от статуса)
  aiEnabled           Boolean   @default(true) @map("ai_enabled")
  aiSummary           String?   @map("ai_summary") @db.Text

  // Флаги
  isDeal              Boolean   @default(false) @map("is_deal")

  // Причины
  reasonHumanRequired String?   @map("reason_human_required") @db.Text
  declineReason       String?   @map("decline_reason") @db.Text

  // Avito-чат
  avitoConversationId String?   @map("avito_conversation_id")
  unreadCount         Int       @default(0) @map("unread_count")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  company  Company    @relation(fields: [companyId], references: [id])
  contact  Contact    @relation(fields: [contactId], references: [id])
  listing  Listing    @relation(fields: [listingId], references: [id])
  agent    Agent?     @relation(fields: [agentId], references: [id])
  assignee User?      @relation("CardAssignee", fields: [assigneeId], references: [id])
  status   CardStatus @relation(fields: [statusId], references: [id])

  messages Message[]
  events   CardEvent[]
  order    Order?

  @@map("cards")
}

// ─────────────────────────────────────────────
// ПЕРЕПИСКА
// ─────────────────────────────────────────────

enum MessageSender {
  client
  ai
  user
}

model Message {
  id           String        @id @default(cuid())
  cardId       String        @map("card_id")
  sender       MessageSender
  authorId     String?       @map("author_id") // user_id если sender = user
  content      String        @db.Text
  attachments  Json?         // массив { url, type, name }
  avitoMsgId   String?       @map("avito_msg_id")
  isRead       Boolean       @default(false) @map("is_read")
  createdAt    DateTime      @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─────────────────────────────────────────────
// ЖУРНАЛ СОБЫТИЙ (EVENT LOG)
// ─────────────────────────────────────────────

model CardEvent {
  id             String           @id @default(cuid())
  cardId         String           @map("card_id")
  type           String           // "status_changed", "ai_toggled", "message_received", etc.
  fromStatusId   String?          @map("from_status_id")
  toStatusId     String?          @map("to_status_id")
  source         TransitionSource
  createdById    String?          @map("created_by_id")
  metadata       Json?            // доп. данные события

  createdAt DateTime @default(now()) @map("created_at")

  card       Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  fromStatus CardStatus? @relation("EventFromStatus", fields: [fromStatusId], references: [id])
  toStatus   CardStatus? @relation("EventToStatus", fields: [toStatusId], references: [id])
  createdBy  User?       @relation(fields: [createdById], references: [id])

  @@map("card_events")
}

// ─────────────────────────────────────────────
// ЗАКАЗЫ И ДОСТАВКА
// ─────────────────────────────────────────────

model Order {
  id              String   @id @default(cuid())
  cardId          String   @unique @map("card_id")
  avitoOrderId    String   @unique @map("avito_order_id")
  amount          Decimal  @db.Decimal(12, 2)
  items           Json     // [{ title, quantity, price }]

  // Доставка
  deliveryType    String?  @map("delivery_type")
  pvzAddress      String?  @map("pvz_address") @db.Text
  trackingCode    String?  @map("tracking_code")
  barcode         String?
  externalStatus  String?  @map("external_status") // статус из Avito
  estimatedDate   DateTime? @map("estimated_date")
  receivedAt      DateTime? @map("received_at")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("orders")
}
